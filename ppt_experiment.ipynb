    "from pathlib import Path\n",
    "\n",
    "\n",
    "# Search entire current working directory recursively\n",
    "db_files = list(Path.cwd().rglob(\"ppt_engine.db\"))\n",
    "\n",
    "print(\"Found DB files:\\n\")\n",
    "\n",
    "for db_file in db_files:\n",
    "    print(db_file)\n",
    "\n",
    "    # Delete file\n",
    "    db_file.unlink()\n",
    "\n",
    "    print(f\"Deleted: {db_file}\")"
   ]
  }
